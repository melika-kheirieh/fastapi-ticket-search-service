# Application
APP_NAME=FastAPI Ticket Search Service
ENVIRONMENT=local
LOG_LEVEL=INFO

# PostgreSQL
DATABASE_URL=postgresql+psycopg://ticket_user:ticket_password@localhost:5432/ticket_db

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
TICKET_SEARCH_INDEX=tickets_v1

# Celery and Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Outbox processing
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_RETRY_COUNT=3
OUTBOX_PROCESSING_TIMEOUT_SECONDS=300
OUTBOX_BEAT_SCHEDULE_SECONDS=10.0
